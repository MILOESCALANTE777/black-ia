import { useState } from 'react';
import { motion } from 'framer-motion';
import { Search } from 'lucide-react';

const MARKETS = [
  { symbol: 'BTC', name: 'Bitcoin', price: 67432.21, change: 2.34 },
  { symbol: 'ETH', name: 'Ethereum', price: 3521.87, change: 1.56 },
  { symbol: 'XAU', name: 'Gold Spot', price: 4126.68, change: -0.23 },
  { symbol: 'EUR', name: 'EUR/USD', price: 1.0892, change: 0.12 },
  { symbol: 'GBP', name: 'GBP/USD', price: 1.2745, change: -0.08 },
  { symbol: 'AAPL', name: 'Apple Inc.', price: 195.89, change: 0.87 },
  { symbol: 'TSLA', name: 'Tesla Inc.', price: 248.42, change: -1.23 },
  { symbol: 'NVDA', name: 'NVIDIA', price: 875.31, change: 3.45 },
];

const CATEGORIES = ['All', 'Crypto', 'Forex', 'Stocks', 'Commodities'];

export default function MarketsScreen() {
  const [activeCategory, setActiveCategory] = useState('All');
  const [searchQuery, setSearchQuery] = useState('');

  const filtered = MARKETS.filter((m) => {
    const matchesSearch =
      m.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
      m.symbol.toLowerCase().includes(searchQuery.toLowerCase());
    const matchesCategory =
      activeCategory === 'All' ||
      (activeCategory === 'Crypto' && ['BTC', 'ETH'].includes(m.symbol)) ||
      (activeCategory === 'Forex' && ['EUR', 'GBP'].includes(m.symbol)) ||
      (activeCategory === 'Stocks' && ['AAPL', 'TSLA', 'NVDA'].includes(m.symbol)) ||
      (activeCategory === 'Commodities' && m.symbol === 'XAU');
    return matchesSearch && matchesCategory;
  });

  return (
    <div className="flex-1 flex flex-col bg-black">
      {/* Header */}
      <div
        className="shrink-0 px-6 md:px-8 py-4 md:py-5"
        style={{ background: 'rgba(0,0,0,0.85)', backdropFilter: 'blur(20px)', borderBottom: '1px solid #1C1C1E' }}
      >
        <h3 className="text-xl md:text-2xl font-bold text-white mb-3">Markets</h3>

        <div className="flex flex-col md:flex-row md:items-center gap-3">
          {/* Search */}
          <div className="flex items-center bg-[#1C1C1E] rounded-xl px-4 py-2.5 border border-[#38383A] md:w-72">
            <Search size={18} color="#8E8E93" />
            <input
              type="text"
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              placeholder="Search assets..."
              className="flex-1 bg-transparent text-white text-sm outline-none placeholder:text-[#636366] ml-2"
            />
          </div>

          {/* Categories */}
          <div className="flex gap-2 overflow-x-auto no-scrollbar">
            {CATEGORIES.map((cat) => (
              <button
                key={cat}
                onClick={() => setActiveCategory(cat)}
                className="shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-all"
                style={{
                  background: activeCategory === cat ? '#FFFFFF' : '#1C1C1E',
                  color: activeCategory === cat ? '#000000' : '#8E8E93',
                  border: `1px solid ${activeCategory === cat ? '#FFFFFF' : '#38383A'}`,
                }}
              >
                {cat}
              </button>
            ))}
          </div>
        </div>
      </div>

      {/* Asset List — grid on desktop */}
      <div className="flex-1 overflow-y-auto no-scrollbar px-5 md:px-8 py-3">
        <div className="md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-3">
          {filtered.map((asset, i) => (
            <motion.div
              key={asset.symbol}
              initial={{ opacity: 0, y: 10 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: i * 0.05 }}
              className="flex items-center justify-between py-4 md:py-0 md:p-4 border-b border-[#38383A] md:border md:rounded-2xl md:bg-[#1C1C1E] md:hover:bg-[#2C2C2E] transition-colors cursor-pointer"
              style={{ borderColor: '#38383A' }}
            >
              <div className="flex items-center gap-3">
                <div
                  className="w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold"
                  style={{ background: '#2C2C2E', border: '1px solid #38383A' }}
                >
                  {asset.symbol.slice(0, 2)}
                </div>
                <div>
                  <div className="text-base font-semibold text-white">{asset.symbol}</div>
                  <div className="text-xs text-[#8E8E93]">{asset.name}</div>
                </div>
              </div>
              <div className="text-right">
                <div className="text-base font-medium text-white">
                  ${asset.price.toLocaleString(undefined, { minimumFractionDigits: 2 })}
                </div>
                <div
                  className="text-xs font-medium"
                  style={{ color: asset.change >= 0 ? '#34C759' : '#FF3B30' }}
                >
                  {asset.change >= 0 ? '+' : ''}{asset.change}%
                </div>
              </div>
            </motion.div>
          ))}
        </div>
      </div>
    </div>
  );
}
